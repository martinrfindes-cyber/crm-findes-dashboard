# Copiá este archivo a .env.local y completá los valores.

# ─── Chatwoot ───
CHATWOOT_BASE_URL=https://findes-chatwoot.7yidoh.easypanel.host
CHATWOOT_ACCOUNT_ID=2
# Access Token de un AGENTE de Chatwoot (Perfil → Access Token). Solo server-side.
CHATWOOT_AGENT_TOKEN=

# ─── Auth del dashboard ───
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
# Agentes habilitados. JSON array de { username, password, name }.
AUTH_USERS=[{"username":"martin","password":"CAMBIAR","name":"Martín"}]
